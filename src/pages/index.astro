---
import BaseLayout from '../layouts/BaseLayout.astro';
import CurriculumCard from '../components/CurriculumCard.astro';
import { getHomepageSections } from '../lib/content';

const sections = await getHomepageSections();
---

<BaseLayout
  title="Field Notes Curriculum"
  description="Published curriculum notes with links, tables, and embedded references."
>
  <section class="max-w-3xl">
    <p class="m-0 text-xs uppercase tracking-[0.18em] text-ink-500">Knowledge Base</p>
    <h1 class="mt-3 font-display text-4xl text-ink-900 md:text-5xl">Pick a curriculum and read through.</h1>
    <p class="mt-4 text-lg text-ink-700">
      A curated set of publishable notes grouped by subject domain so the library stays
      browsable as it grows.
    </p>
  </section>

  <section class="mt-8 rounded-2xl border border-ink-100 bg-white/75 p-5 shadow-sm">
    <p class="m-0 text-xs uppercase tracking-[0.18em] text-ink-500">Browse By Topic</p>
    <div class="mt-4 flex flex-wrap gap-2">
      {sections.map((section) => (
        <a
          class="rounded-full border border-ink-100 bg-paper px-3 py-1.5 text-sm text-ink-700 no-underline transition hover:border-accent/40 hover:text-accent"
          href={`#${section.key}`}
        >
          {section.title}
        </a>
      ))}
    </div>
  </section>

  <div class="mt-12 space-y-12">
    {sections.map((section) => (
      <section id={section.key} class="scroll-mt-24">
        <div class="mb-5 max-w-3xl">
          <p class="m-0 text-xs uppercase tracking-[0.18em] text-ink-500">Section</p>
          <h2 class="mt-2 font-display text-3xl text-ink-900">{section.title}</h2>
          <p class="mt-2 text-ink-700">{section.description}</p>
        </div>

        <div class="grid gap-5 md:grid-cols-2">
          {section.items.map((item) => <CurriculumCard item={item} />)}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
