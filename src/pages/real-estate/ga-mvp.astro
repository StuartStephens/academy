    }

    async function getHudNearby(serviceUrl, outFields, latitude, longitude, radiusMiles, limit = 30) {
      const params = new URLSearchParams({
        where: '1=1',
        outFields,
        returnGeometry: 'true',
        geometry: JSON.stringify({
          x: longitude,
          y: latitude,
          spatialReference: { wkid: 4326 },
        }),
        geometryType: 'esriGeometryPoint',
        inSR: '4326',
        spatialRel: 'esriSpatialRelIntersects',
        distance: String(radiusMiles),
        units: 'esriSRUnit_StatuteMile',
        outSR: '4326',
        resultRecordCount: String(limit),
        f: 'json',
      });

      const data = await fetchJson(`${serviceUrl}?${params.toString()}`);
      const features = Array.isArray(data.features) ? data.features : [];

      return features
        .map((feature) => {
          const attrs = feature.attributes || {};
          const lat = feature.geometry?.y;
          const lon = feature.geometry?.x;
          if (!Number.isFinite(lat) || !Number.isFinite(lon)) {
            return null;
          }

          return {
            attributes: attrs,
            latitude: lat,
            longitude: lon,
            distanceMiles: haversineMiles(latitude, longitude, lat, lon),
          };
        })
        .filter(Boolean)
        .sort((a, b) => a.distanceMiles - b.distanceMiles);
    }

