    function getParcelServiceForLocation(location, fips) {
      const region = (location.region || '').toLowerCase();
      if (!['georgia', 'ga'].includes(region)) {
        return {
          service: atlantaParcelsService,
          label: 'City of Atlanta tax parcels (fallback outside GA)',
          quality: 'fallback',
        };
      }

      if (fips.county === '121') {
        return {
          service: fultonParcelsService,
          label: 'Fulton County tax parcels',
          quality: 'county',
        };
      }

      if (fips.county === '089') {
        return {
          service: dekalbParcelsService,
          label: 'DeKalb County tax parcels',
          quality: 'county',
        };
      }

      if (fips.county === '067') {
        return {
          service: cobbParcelsService,
          label: 'Cobb County parcel records',
          quality: 'county',
        };
      }

      if (fips.county === '135') {
        return {
          service: gwinnettParcelsService,
          label: 'Gwinnett County parcel records',
          quality: 'county',
        };
      }

      return {
        service: atlantaParcelsService,
        label: 'City of Atlanta tax parcels (proxy fallback)',
        quality: 'fallback',
      };
    }

    function extractCentroidFromPolygonGeometry(geometry) {
      const rings = Array.isArray(geometry?.rings) ? geometry.rings : [];
      let sumX = 0;
      let sumY = 0;
      let count = 0;

      for (const ring of rings) {
        if (!Array.isArray(ring)) {
          continue;
        }

        for (const coordinate of ring) {
          const x = coordinate?.[0];
          const y = coordinate?.[1];
          if (!Number.isFinite(x) || !Number.isFinite(y)) {
            continue;
          }

          sumX += x;
          sumY += y;
          count += 1;
        }
      }

      if (count === 0) {
        return null;
      }

      return {
        longitude: sumX / count,
        latitude: sumY / count,
      };
    }

    function parseTaxYear(rawValue) {
      const numeric = Number(rawValue);
      if (Number.isFinite(numeric) && numeric > 1900 && numeric < 2100) {
        return Math.round(numeric);
      }

      const text = String(rawValue || '');
      const match = text.match(/(19|20)\d{2}/);
      if (!match) {
        return null;
      }

      return Number(match[0]);
    }

    async function fetchParcelRecords(location, fips) {
      const selected = getParcelServiceForLocation(location, fips);
      const service = selected.service;

      const params = new URLSearchParams({
        where: '1=1',
        outFields: service.outFields,
        returnGeometry: 'true',
        geometry: JSON.stringify({
          x: location.longitude,
          y: location.latitude,
          spatialReference: { wkid: 4326 },
        }),
        geometryType: 'esriGeometryPoint',
        inSR: '4326',
        spatialRel: 'esriSpatialRelIntersects',
        distance: String(PARCEL_RADIUS_MILES),
        units: 'esriSRUnit_StatuteMile',
        outSR: '4326',
        resultRecordCount: String(PARCEL_FETCH_LIMIT),
        f: 'json',
      });

      const data = await fetchJson(`${service.query}?${params.toString()}`, 45000);
      const features = Array.isArray(data.features) ? data.features : [];
      const records = [];

      for (const feature of features) {
        const attributes = feature.attributes || {};
        const serviceAddressField = service.fields.address;
        const addressRaw = serviceAddressField ? attributes[serviceAddressField] : null;
        const address = String(addressRaw || '').trim();

        const centroid = extractCentroidFromPolygonGeometry(feature.geometry);
        if (!centroid) {
          continue;
        }

        const appraisedValue = service.fields.value
          ? toNumber(attributes[service.fields.value])
          : null;
        const units = service.fields.units ? toNumber(attributes[service.fields.units]) : null;
        const classLabel = service.fields.classDescription
          ? String(attributes[service.fields.classDescription] || '').trim()
          : '';
        const neighborhood = service.fields.neighborhood
          ? String(attributes[service.fields.neighborhood] || '').trim()
          : '';
        const parcelId = service.fields.parcelId
          ? String(attributes[service.fields.parcelId] || '').trim()
          : '';
        const taxYear = service.fields.taxYear ? parseTaxYear(attributes[service.fields.taxYear]) : null;

        const landAssessed = toNumber(attributes.LANDASSESS);
        const improvementAssessed = toNumber(attributes.IMPRASSESS);
        const combinedAssessed =
          landAssessed !== null && improvementAssessed !== null
            ? landAssessed + improvementAssessed
            : null;

        const derivedValue = appraisedValue ?? combinedAssessed;

        const normalizedAddress = address || `${parcelId || 'Parcel'} (${centroid.latitude.toFixed(5)}, ${centroid.longitude.toFixed(5)})`;

        records.push({
          address: normalizedAddress,
          parcelId,
          classLabel,
          neighborhood,
          appraisedValue: Number.isFinite(derivedValue) ? derivedValue : null,
          units,
          taxYear,
          latitude: centroid.latitude,
          longitude: centroid.longitude,
          distanceMiles: haversineMiles(
            location.latitude,
            location.longitude,
            centroid.latitude,
            centroid.longitude
          ),
          source: selected.label,
          sourceQuality: selected.quality,
        });
      }

      records.sort((a, b) => a.distanceMiles - b.distanceMiles);

      return {
        records,
        sourceLabel: selected.label,
        sourceQuality: selected.quality,
      };
    }

    function normalizeAddressForMatching(value) {
      return String(value || '')
        .toLowerCase()
        .replace(/[^a-z0-9\s]/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
    }

    async function fetchOnMarketAddressSet(location) {
      const apiKey = `${publicRentcastApiKey || ''}`.trim();
      if (!apiKey) {
        return { enabled: false, addresses: new Set(), reason: 'missing-key', detail: null };
      }

      const city = (location.city || '').trim();
      const state = (location.region || '').trim();
      if (!city || !state) {
        return { enabled: false, addresses: new Set(), reason: 'missing-city-state', detail: null };
      }

      const params = new URLSearchParams({
        city,
        state,
        status: 'active',
        limit: '500',
      });

      const url = `https://api.rentcast.io/v1/listings/sale?${params.toString()}`;

      const controller = new AbortController();
      const timer = setTimeout(() => controller.abort(), 30000);
      try {
        const response = await fetch(url, {
          method: 'GET',
          mode: 'cors',
          signal: controller.signal,
          headers: {
            'X-Api-Key': apiKey,
          },
        });

        if (!response.ok) {
          const errorText = await response.text();
          throw new Error(`Rentcast listings request failed (${response.status}): ${errorText.slice(0, 120)}`);
        }

        const rows = await response.json();
        const addressSet = new Set();

        if (Array.isArray(rows)) {
          for (const row of rows) {
            const candidateAddress =
              row?.formattedAddress ||
              row?.addressLine1 ||
              row?.address ||
              row?.property?.formattedAddress ||
              row?.property?.addressLine1 ||
              row?.propertyAddress;

            const normalized = normalizeAddressForMatching(candidateAddress);
            if (normalized) {
              addressSet.add(normalized);
            }
          }
        }

        return { enabled: true, addresses: addressSet, reason: null, detail: `Matched against ${addressSet.size} active listing addresses for ${city}, ${state}.` };
      } finally {
        clearTimeout(timer);
      }
    }

    function updateOnMarketStatus(text, tone = 'neutral') {
      if (!elements.onMarketStatus) {
        return;
      }

      elements.onMarketStatus.textContent = text;
      elements.onMarketStatus.className = 'mt-2 text-xs';
      if (tone === 'error') {
        elements.onMarketStatus.classList.add('text-warning');
      } else if (tone === 'success') {
        elements.onMarketStatus.classList.add('text-success');
      } else {
        elements.onMarketStatus.classList.add('text-ink-500');
      }
    }

    function readListingFilters() {
      return {
        minValue: toNumber(elements.listingMin?.value),
        maxValue: toNumber(elements.listingMax?.value),
        minUnits: toNumber(elements.listingUnits?.value),
        text: String(elements.listingText?.value || '').trim().toLowerCase(),
        sort: elements.listingSort?.value || 'distance-asc',
        onMarketOnly: Boolean(elements.listingOnMarket?.checked),
      };
    }

    function applyListingFilters() {
      const filters = readListingFilters();
      let filtered = [...listingState.records];

      filtered = filtered.filter((record) => {
        if (filters.minValue !== null) {
          if (record.appraisedValue === null || record.appraisedValue < filters.minValue) {
            return false;
          }
        }

        if (filters.maxValue !== null) {
          if (record.appraisedValue === null || record.appraisedValue > filters.maxValue) {
            return false;
          }
        }

        if (filters.minUnits !== null) {
          if (record.units === null || record.units < filters.minUnits) {
            return false;
          }
        }

        if (filters.text) {
          const haystack = `${record.address} ${record.neighborhood} ${record.classLabel} ${record.parcelId}`.toLowerCase();
          if (!haystack.includes(filters.text)) {
            return false;
          }
        }

        if (filters.onMarketOnly) {
          if (!record.isOnMarket) {
            return false;
          }
        }

        return true;
      });

      if (filters.sort === 'value-desc') {
        filtered.sort((a, b) => (b.appraisedValue || -1) - (a.appraisedValue || -1));
      } else if (filters.sort === 'value-asc') {
        filtered.sort((a, b) => (a.appraisedValue || Number.MAX_SAFE_INTEGER) - (b.appraisedValue || Number.MAX_SAFE_INTEGER));
      } else if (filters.sort === 'units-desc') {
        filtered.sort((a, b) => (b.units || -1) - (a.units || -1));
      } else {
        filtered.sort((a, b) => a.distanceMiles - b.distanceMiles);
      }

      listingState.filtered = filtered;
      renderListingCards();
    }

    function renderListingCards() {
      const sourceBadge = listingState.sourceLabel || 'waiting for search';
      elements.listingsSource.textContent = `Source: ${sourceBadge}`;

      if (elements.listingOnMarket) {
        elements.listingOnMarket.disabled = !listingState.onMarketEnabled;
        elements.listingOnMarket.title = listingState.onMarketEnabled
          ? 'Show only listings currently marked active in listing feed.'
          : 'Set PUBLIC_RENTCAST_API_KEY to enable on-market filter.';
      }

      elements.listingList.innerHTML = '';
      const total = listingState.records.length;
      const filteredCount = listingState.filtered.length;
      const shown = Math.min(filteredCount, PARCEL_RENDER_LIMIT);

      if (total === 0) {
        elements.listingsSummary.textContent =
          'No parcel records available here yet. Try another nearby Georgia address.';
        const empty = document.createElement('article');
        empty.className = 'rounded-xl border border-ink-100 bg-paper p-4 text-sm text-ink-500';
        empty.textContent = 'No property records found for this search area.';
        elements.listingList.appendChild(empty);
        return;
      }

      if (filteredCount === 0) {
        elements.listingsSummary.textContent =
          `0 matches for current filters (${total} loaded). Clear filters to see listings.`;
        const emptyFiltered = document.createElement('article');
        emptyFiltered.className = 'rounded-xl border border-ink-100 bg-paper p-4 text-sm text-ink-500';
        emptyFiltered.textContent =
          'No properties match the active filters. Try removing min/max/unit/text filters.';
        elements.listingList.appendChild(emptyFiltered);
        return;
      }

      elements.listingsSummary.textContent = `Showing ${shown} of ${listingState.filtered.length} filtered records (${total} loaded).`;

      for (const record of listingState.filtered.slice(0, PARCEL_RENDER_LIMIT)) {
        const card = document.createElement('article');
        card.className = 'rounded-xl border border-ink-100 bg-white p-4 shadow-sm';

        const address = document.createElement('h3');
        address.className = 'm-0 font-display text-xl text-ink-900';
        address.textContent = record.address;
        card.appendChild(address);

        const meta = document.createElement('p');
        meta.className = 'mt-1 text-xs text-ink-500';
        meta.textContent = `${record.neighborhood || 'Area N/A'} | ${record.classLabel || 'Class N/A'} | ${formatMiles(record.distanceMiles)} | ${record.isOnMarket ? 'On market' : 'Not verified on market'}`;
        card.appendChild(meta);

        const stats = document.createElement('div');
        stats.className = 'mt-3 grid grid-cols-2 gap-2 text-xs';

        const fields = [
          { label: 'Appraised', value: formatMoney(record.appraisedValue) },
          { label: 'Units', value: formatNumber(record.units) },
          { label: 'Market', value: record.isOnMarket ? 'Active' : 'Unknown' },
          { label: 'Tax Year', value: record.taxYear ? String(record.taxYear) : 'N/A' },
          { label: 'Parcel ID', value: record.parcelId || 'N/A' },
        ];

        for (const field of fields) {
          const box = document.createElement('div');
          box.className = 'rounded-lg border border-ink-100 bg-paper p-2';

          const key = document.createElement('p');
          key.className = 'm-0 text-[10px] uppercase tracking-[0.12em] text-ink-500';
          key.textContent = field.label;

          const value = document.createElement('p');
          value.className = 'mt-1 mb-0 text-sm text-ink-900';
          value.textContent = field.value;

          box.appendChild(key);
          box.appendChild(value);
          stats.appendChild(box);
        }

        card.appendChild(stats);

        const links = document.createElement('div');
        links.className = 'mt-3 flex flex-wrap gap-2 text-xs';
        const encodedAddress = encodeURIComponent(record.address);

        const zillow = document.createElement('a');
        zillow.className =
          'rounded-full border border-ink-200 bg-paper px-3 py-1 text-ink-700 no-underline hover:border-accent hover:text-accent';
        zillow.href = `https://www.zillow.com/homes/${encodedAddress}_rb/`;
        zillow.target = '_blank';
        zillow.rel = 'noopener noreferrer';
        zillow.textContent = 'Search on Zillow';

        const maps = document.createElement('a');
        maps.className =
          'rounded-full border border-ink-200 bg-paper px-3 py-1 text-ink-700 no-underline hover:border-accent hover:text-accent';
        maps.href = `https://www.google.com/maps/search/${encodedAddress}`;
        maps.target = '_blank';
        maps.rel = 'noopener noreferrer';
        maps.textContent = 'Open in Maps';

        links.appendChild(zillow);
        links.appendChild(maps);
        card.appendChild(links);

        elements.listingList.appendChild(card);
      }
    }

    function resetListingFilters() {
      elements.listingMin.value = '';
      elements.listingMax.value = '';
      elements.listingUnits.value = '';
      elements.listingText.value = '';
      elements.listingSort.value = 'distance-asc';
      if (elements.listingOnMarket) {
        elements.listingOnMarket.checked = false;
      }
      applyListingFilters();
    }

    async function loadLeaflet() {
      if (mapState.L) {
        return mapState.L;
      }

      if (mapState.loading) {
        return mapState.loading;
      }

      mapState.loading = new Promise((resolve, reject) => {
        const css = document.createElement('link');
        css.rel = 'stylesheet';
        css.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
        document.head.appendChild(css);

        const script = document.createElement('script');
        script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
        script.async = true;
        script.onload = () => {
          if (window.L) {
            mapState.L = window.L;
            resolve(window.L);
            return;
          }

          reject(new Error('Leaflet failed to initialize.'));
        };
        script.onerror = () => reject(new Error('Leaflet script could not load.'));
        document.head.appendChild(script);
      });

      return mapState.loading;
    }

    async function updateMap(latitude, longitude, amenities, lihtcSites, publicHousingSites) {
      const L = await loadLeaflet();

      if (!mapState.map) {
        mapState.map = L.map(elements.map, { zoomControl: true }).setView([latitude, longitude], 13);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          maxZoom: 19,
          attribution: '&copy; OpenStreetMap contributors',
        }).addTo(mapState.map);

        mapState.layer = L.layerGroup().addTo(mapState.map);
      }

      mapState.map.setView([latitude, longitude], 13);
      mapState.layer.clearLayers();

      L.circleMarker([latitude, longitude], {
        radius: 9,
        color: '#21557a',
        fillColor: '#21557a',
        fillOpacity: 0.3,
        weight: 2,
      })
        .addTo(mapState.layer)
        .bindPopup('Search location');

      for (const amenity of amenities.slice(0, MAP_AMENITY_LIMIT)) {
        const color = amenity.kind === 'Market' ? '#8a5c1f' : '#2f6a4f';
        L.circleMarker([amenity.latitude, amenity.longitude], {
          radius: 5,
          color,
          fillColor: color,
          fillOpacity: 0.4,
          weight: 1,
        })
          .addTo(mapState.layer)
          .bindPopup(`${amenity.kind}: ${amenity.name} (${formatMiles(amenity.distanceMiles)})`);
      }

      const combinedHousing = [...lihtcSites, ...publicHousingSites].slice(0, MAP_HOUSING_LIMIT);
      for (const housing of combinedHousing) {
        const label = housing.label || 'HUD housing point';

        L.circleMarker([housing.latitude, housing.longitude], {
          radius: 6,
          color: '#8f3a27',
          fillColor: '#8f3a27',
          fillOpacity: 0.35,
          weight: 1,
        })
          .addTo(mapState.layer)
          .bindPopup(`${label} (${formatMiles(housing.distanceMiles)})`);
      }
    }

    function updateExternalLinks(query) {
      const encoded = encodeURIComponent(query);
      elements.zillowLink.href = `https://www.zillow.com/homes/${encoded}_rb/`;
      elements.googleLink.href = `https://www.google.com/maps/search/${encoded}%20homes`;
    }

    async function runAnalysis(query) {
      const cleaned = query.trim();
      if (!cleaned) {
        setStatus('Enter an address, city, or ZIP first.', 'error');
        return;
      }

      setWarning('');
      setStatus('Geocoding location and loading public datasets...');
      elements.submit.disabled = true;
      elements.submit.textContent = 'Loading...';
      elements.listingsSummary.textContent = 'Loading parcel records for this area...';
      updateOnMarketStatus('On-market feed status: checking key and listing feed...');

      try {
        const location = await geocode(cleaned);
        const fips = await getFips(location.latitude, location.longitude);

        if (
          location.region &&
          !['georgia', 'ga'].includes(location.region.toLowerCase())
        ) {
          addWarning(
            'This MVP is tuned for Georgia workflows, but the free national APIs still returned results for this location.'
          );
        }

        setStatus('Pulling core datasets (demographics, jobs, weather, housing, parcels)...');

        const [acs, employment, vouchers, lihtc, publicHousing, weather, parcels] = await Promise.all([
          getAcsData(fips),
          getCountyEmployment(fips),
          getHudVouchersByTract(fips.tractGeoid),
          getHudNearby(
            hudServices.lihtc,
            'PROJECT,PROJ_ADD,N_UNITS,LI_UNITS,YR_PIS',
            location.latitude,
            location.longitude,
            HUD_RADIUS_MILES,
            40
          ),
          getHudNearby(
            hudServices.publicHousing,
            'PROJECT_NAME,TOTAL_UNITS,PCT_OCCUPIED,FORMAL_PARTICIPANT_NAME',
            location.latitude,
            location.longitude,
            HUD_RADIUS_MILES,
            40
          ),
          getWeather(location.latitude, location.longitude),
          fetchParcelRecords(location, fips),
        ]);

        let onMarketLookup = { enabled: false, addresses: new Set(), reason: null };
        try {
          onMarketLookup = await fetchOnMarketAddressSet(location);
        } catch (onMarketError) {
          const message = onMarketError instanceof Error ? onMarketError.message : 'Unknown error';
          console.info(`On-market lookup failed: ${message}`);
          onMarketLookup = {
            enabled: false,
            addresses: new Set(),
            reason: 'request-failed',
            detail: message,
          };
        }

        const normalizedAddresses = onMarketLookup.addresses;
        const recordsWithMarketFlag = parcels.records.map((record) => {
          const normalized = normalizeAddressForMatching(record.address);
          const isOnMarket = normalized ? normalizedAddresses.has(normalized) : false;
          return {
            ...record,
            isOnMarket,
          };
        });

        listingState.records = recordsWithMarketFlag;
        listingState.sourceLabel = parcels.sourceLabel;
        listingState.center = { latitude: location.latitude, longitude: location.longitude };
        listingState.onMarketByAddress = normalizedAddresses;
        listingState.onMarketEnabled = onMarketLookup.enabled;

        if (!onMarketLookup.enabled && elements.listingOnMarket?.checked) {
          elements.listingOnMarket.checked = false;
        }

        if (!onMarketLookup.enabled) {
          if (onMarketLookup.reason === 'missing-key') {
            addWarning(
              'On-market filter is disabled. Add PUBLIC_RENTCAST_API_KEY to enable active listing matching.'
            );
            updateOnMarketStatus(
              'On-market feed status: disabled (missing PUBLIC_RENTCAST_API_KEY).',
              'error'
            );
          } else if (onMarketLookup.reason === 'missing-city-state') {
            updateOnMarketStatus(
              'On-market feed status: disabled (geocoder did not return city/state clearly for this search).',
              'error'
            );
          } else if (onMarketLookup.reason === 'request-failed') {
            addWarning(
              'On-market listing lookup is temporarily unavailable. Browse results are still shown.'
            );
            updateOnMarketStatus(
              `On-market feed status: request failed (${onMarketLookup.detail || 'unknown error'}).`,
              'error'
            );
          } else {
            updateOnMarketStatus('On-market feed status: unavailable for this query.', 'error');
          }
        } else {
          updateOnMarketStatus(
            `On-market feed status: connected. ${onMarketLookup.detail || ''}`.trim(),
            'success'
          );
        }

        setStatus('Pulling nearby amenities...');
        let amenities = [];
        try {
          amenities = await getAmenities(location.latitude, location.longitude);
        } catch (amenitiesError) {
          const details = amenitiesError instanceof Error ? amenitiesError.message : 'Unknown error';
          console.info(`Amenities request failed: ${details}. Continuing without amenity points.`);
          addWarning(
            'Nearby grocery/market data is temporarily unavailable (Overpass timeout). All other sections and listings are still loaded.'
          );
        }

        const access = computeAccessScore(amenities);

        elements.location.textContent = location.label;
        elements.countyTract.textContent = `${fips.countyName} | Tract ${fips.tractGeoid}`;
        elements.homeValue.textContent = formatMoney(acs?.medianHomeValue ?? null);
        elements.income.textContent = formatMoney(acs?.medianIncome ?? null);
        elements.accessScore.textContent = `${access.score} / 100`;
        elements.groceryCount.textContent = formatNumber(access.groceryCount);
        elements.marketCount.textContent = formatNumber(access.marketCount);
        elements.lihtcCount.textContent = formatNumber(lihtc.length);
        elements.publicHousingCount.textContent = formatNumber(publicHousing.length);

        renderList(
          elements.amenityList,
          amenities.slice(0, 10).map((item) => `${item.kind}: ${item.name} (${formatMiles(item.distanceMiles)})`),
          'No grocery or marketplace points found in the search radius.'
        );

        renderDefinitionList(elements.demographics, [
          { label: 'Population', value: formatNumber(acs?.population ?? null) },
          { label: 'Median rent', value: formatMoney(acs?.medianRent ?? null) },
          { label: 'Housing units', value: formatNumber(acs?.housingUnits ?? null) },
          { label: 'Occupancy rate', value: formatPercent(acs?.occupancyRate ?? null) },
          { label: 'Bachelor+ share', value: formatPercent(acs?.bachelorPlusRate ?? null) },
        ]);

        renderList(
          elements.employers,
          employment.map(
            (row) =>
              `${row.label.replace(/^\d{2}\s*/, '')}: ${formatNumber(row.employment)} jobs, ${formatNumber(row.establishments)} establishments`
          ),
          'Employment sector data not available for this county.'
        );

        renderDefinitionList(elements.weather, [
          {
            label: 'Temperature',
            value:
              weather?.current?.temperature_2m !== undefined
                ? `${Math.round(weather.current.temperature_2m)}${weather.currentUnits?.temperature_2m || 'F'}`
                : 'N/A',
          },
          {
            label: 'Feels like',
            value:
              weather?.current?.apparent_temperature !== undefined
                ? `${Math.round(weather.current.apparent_temperature)}${weather.currentUnits?.apparent_temperature || 'F'}`
                : 'N/A',
          },
          {
            label: 'Humidity',
            value:
              weather?.current?.relative_humidity_2m !== undefined
                ? `${Math.round(weather.current.relative_humidity_2m)}%`
                : 'N/A',
          },
          {
            label: 'Wind',
            value:
              weather?.current?.wind_speed_10m !== undefined
                ? `${Math.round(weather.current.wind_speed_10m)} ${weather.currentUnits?.wind_speed_10m || 'mph'}`
                : 'N/A',
          },
          {
            label: 'Today high / low',
            value:
              Array.isArray(weather?.daily?.temperature_2m_max) &&
              Array.isArray(weather?.daily?.temperature_2m_min) &&
              weather.daily.temperature_2m_max.length > 0
                ? `${Math.round(weather.daily.temperature_2m_max[0])} / ${Math.round(weather.daily.temperature_2m_min[0])}${weather.dailyUnits?.temperature_2m_max || 'F'}`
                : 'N/A',
          },
        ]);

        const housingRows = [];

        for (const site of lihtc.slice(0, 6)) {
          const label = site.attributes.PROJECT || 'LIHTC site';
          const units = toNumber(site.attributes.LI_UNITS) ?? toNumber(site.attributes.N_UNITS);
          housingRows.push(`${label}: ${formatNumber(units)} units (${formatMiles(site.distanceMiles)})`);
        }

        for (const site of publicHousing.slice(0, 6)) {
          const label = site.attributes.PROJECT_NAME || 'Public housing site';
          const units = toNumber(site.attributes.TOTAL_UNITS);
          housingRows.push(`${label}: ${formatNumber(units)} units (${formatMiles(site.distanceMiles)})`);
        }

        renderList(elements.housingList, housingRows, 'No nearby LIHTC or public housing points found.');

        if (vouchers) {
          const pct = vouchers.voucherPct !== null ? `${vouchers.voucherPct.toFixed(1)}%` : 'N/A';
          elements.voucherTract.textContent = `Housing Choice Voucher households in tract: ${formatNumber(vouchers.vouchers)} (${pct} of renter households).`;
        } else {
          elements.voucherTract.textContent =
            'Housing Choice Voucher tract aggregate not available or suppressed for confidentiality.';
        }

        await updateMap(
          location.latitude,
          location.longitude,
          amenities,
          lihtc.map((item) => ({
            latitude: item.latitude,
            longitude: item.longitude,
            distanceMiles: item.distanceMiles,
            label: item.attributes.PROJECT || 'LIHTC site',
          })),
          publicHousing.map((item) => ({
            latitude: item.latitude,
            longitude: item.longitude,
            distanceMiles: item.distanceMiles,
            label: item.attributes.PROJECT_NAME || 'Public housing site',
          }))
        );

        applyListingFilters();

        if (parcels.sourceQuality === 'fallback') {
          addWarning(
            'Parcel listing proxy is using the Atlanta fallback source for this area. Coverage/fields may be thinner than county-native sources.'
          );
        }

        updateExternalLinks(cleaned);
        setStatus('Analysis complete.', 'success');
      } catch (error) {
        console.error(error);
        setStatus(
          error instanceof Error
            ? error.message
            : 'Unable to complete the search due to an unexpected error.',
          'error'
        );
      } finally {
        elements.submit.disabled = false;
        elements.submit.textContent = 'Analyze area';
      }
    }

    elements.form?.addEventListener('submit', (event) => {
      event.preventDefault();
      runAnalysis(elements.input?.value || '');
    });

    const listingFilterInputs = [
      elements.listingMin,
      elements.listingMax,
      elements.listingUnits,
      elements.listingText,
      elements.listingSort,
      elements.listingOnMarket,
    ];

    for (const input of listingFilterInputs) {
      input?.addEventListener('input', () => applyListingFilters());
      input?.addEventListener('change', () => applyListingFilters());
    }

    elements.listingReset?.addEventListener('click', () => {
      resetListingFilters();
    });

    for (const button of elements.presets) {
      button.addEventListener('click', () => {
        const query = button.getAttribute('data-query') || '';
        if (!query) {
          return;
        }

        elements.input.value = query;
        runAnalysis(query);
      });
    }

    runAnalysis(elements.input?.value || '30303 Atlanta GA');
  </script>
</BaseLayout>
