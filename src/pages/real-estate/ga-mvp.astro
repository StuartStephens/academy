---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Georgia Real Estate Explorer (Free MVP)"
  description="Free Atlanta and Georgia area explorer with nearby groceries, assisted housing signals, demographics, employers, weather, and map context."
>
  <section class="max-w-3xl">
    <p class="m-0 text-xs uppercase tracking-[0.18em] text-ink-500">Free MVP</p>
    <h1 class="mt-3 font-display text-4xl text-ink-900 md:text-5xl">Georgia Real Estate Explorer</h1>
    <p class="mt-4 text-lg text-ink-700">
      This version is intentionally free-data only. It gives strong area intelligence for Atlanta and
      Georgia addresses: amenities, assisted housing layers, neighborhood demographics, employers,
      weather, and a custom walkability-style access score.
    </p>
    <div class="mt-5 flex flex-wrap gap-2 text-xs">
      <span class="rounded-full bg-accentSoft px-3 py-1 text-accent">No paid listing feed</span>
      <span class="rounded-full bg-accentSoft px-3 py-1 text-accent">No scraped Zillow data</span>
      <span class="rounded-full bg-accentSoft px-3 py-1 text-accent">Atlanta + Georgia first</span>
    </div>
  </section>

  <section class="mt-8 rounded-2xl border border-ink-100 bg-white/75 p-5 shadow-sm">
    <p class="m-0 text-xs uppercase tracking-[0.18em] text-ink-500">Search Area</p>
    <form id="ga-search-form" class="mt-4 flex flex-col gap-3 sm:flex-row">
      <label class="sr-only" for="ga-search-input">Address, city, or ZIP</label>
      <input
        id="ga-search-input"
        name="query"
        class="w-full rounded-xl border border-ink-300 bg-paper px-4 py-2.5 text-base text-ink-900 outline-none transition focus:border-accent"
        value="30303 Atlanta GA"
        placeholder="Try 30303 Atlanta GA or 30030 Decatur GA"
        autocomplete="off"
      />
      <button
        id="ga-search-submit"
        type="submit"
        class="rounded-xl border border-accent bg-accent px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-ink-900"
      >
        Analyze area
      </button>
    </form>

    <div class="mt-4 flex flex-wrap gap-2">
      <button
        type="button"
        class="ga-preset rounded-full border border-ink-100 bg-paper px-3 py-1.5 text-xs text-ink-700"
        data-query="30303 Atlanta GA"
      >
        Downtown ATL
      </button>
      <button
        type="button"
        class="ga-preset rounded-full border border-ink-100 bg-paper px-3 py-1.5 text-xs text-ink-700"
        data-query="30306 Atlanta GA"
      >
        Midtown ATL
      </button>
      <button
        type="button"
        class="ga-preset rounded-full border border-ink-100 bg-paper px-3 py-1.5 text-xs text-ink-700"
        data-query="30030 Decatur GA"
      >
        Decatur
      </button>
      <button
        type="button"
        class="ga-preset rounded-full border border-ink-100 bg-paper px-3 py-1.5 text-xs text-ink-700"
        data-query="30080 Smyrna GA"
      >
        Smyrna
      </button>
      <button
        type="button"
        class="ga-preset rounded-full border border-ink-100 bg-paper px-3 py-1.5 text-xs text-ink-700"
        data-query="30144 Kennesaw GA"
      >
        Kennesaw
      </button>
    </div>

    <p id="ga-status" class="mt-4 text-sm text-ink-700">Ready. Enter a Georgia address or ZIP.</p>
    <p id="ga-warning" class="mt-1 text-xs text-warning"></p>
  </section>

  <section class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <article class="rounded-xl border border-ink-100 bg-white/80 p-4 shadow-sm">
      <p class="m-0 text-xs uppercase tracking-[0.14em] text-ink-500">Location</p>
      <p id="ga-location" class="mt-2 text-sm text-ink-900">-</p>
      <p id="ga-county-tract" class="mt-2 text-xs text-ink-500">-</p>
    </article>
    <article class="rounded-xl border border-ink-100 bg-white/80 p-4 shadow-sm">
      <p class="m-0 text-xs uppercase tracking-[0.14em] text-ink-500">Median Home Value</p>
      <p id="ga-home-value" class="mt-2 text-2xl font-display text-ink-900">-</p>
      <p class="mt-1 text-xs text-ink-500">ACS tract estimate</p>
    </article>
    <article class="rounded-xl border border-ink-100 bg-white/80 p-4 shadow-sm">
      <p class="m-0 text-xs uppercase tracking-[0.14em] text-ink-500">Median Income</p>
      <p id="ga-income" class="mt-2 text-2xl font-display text-ink-900">-</p>
      <p class="mt-1 text-xs text-ink-500">ACS household estimate</p>
    </article>
    <article class="rounded-xl border border-ink-100 bg-white/80 p-4 shadow-sm">
      <p class="m-0 text-xs uppercase tracking-[0.14em] text-ink-500">Local Access Score</p>
      <p id="ga-access-score" class="mt-2 text-2xl font-display text-ink-900">-</p>
      <p class="mt-1 text-xs text-ink-500">Custom grocery/market proxy</p>
    </article>
  </section>

  <section class="mt-8 grid gap-6 lg:grid-cols-[1.35fr_1fr]">
    <article class="rounded-2xl border border-ink-100 bg-white/80 p-5 shadow-sm">
      <p class="m-0 text-xs uppercase tracking-[0.18em] text-ink-500">Map Context</p>
      <h2 class="mt-2 font-display text-2xl text-ink-900">Nearby Essentials and Housing Layers</h2>
      <p class="mt-2 text-sm text-ink-700">
        Blue is your search point. Green marks groceries and markets. Red marks nearby affordable
        or assisted housing points from HUD layers.
      </p>
      <div id="ga-map" class="mt-4 h-[24rem] w-full rounded-xl border border-ink-100 bg-ink-50"></div>
      <p class="mt-3 text-xs text-ink-500">Map tiles: OpenStreetMap. Layers update per search.</p>
    </article>

    <article class="rounded-2xl border border-ink-100 bg-white/80 p-5 shadow-sm">
      <p class="m-0 text-xs uppercase tracking-[0.18em] text-ink-500">Nearby Food Access</p>
      <h2 class="mt-2 font-display text-2xl text-ink-900">Groceries and Markets</h2>
      <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
        <div class="rounded-lg border border-ink-100 bg-paper p-3">
          <p class="m-0 text-xs uppercase tracking-[0.14em] text-ink-500">Groceries</p>
          <p id="ga-grocery-count" class="mt-1 text-xl font-display text-ink-900">-</p>
        </div>
        <div class="rounded-lg border border-ink-100 bg-paper p-3">
          <p class="m-0 text-xs uppercase tracking-[0.14em] text-ink-500">Markets</p>
          <p id="ga-market-count" class="mt-1 text-xl font-display text-ink-900">-</p>
        </div>
      </div>
      <ul id="ga-amenity-list" class="mt-4 space-y-2 text-sm text-ink-700"></ul>
    </article>
  </section>

  <section class="mt-8 grid gap-6 lg:grid-cols-3">
    <article class="rounded-2xl border border-ink-100 bg-white/80 p-5 shadow-sm">
      <p class="m-0 text-xs uppercase tracking-[0.18em] text-ink-500">Neighborhood</p>
      <h2 class="mt-2 font-display text-2xl text-ink-900">Demographics</h2>
      <dl id="ga-demographics" class="mt-4 space-y-2 text-sm text-ink-700"></dl>
    </article>

    <article class="rounded-2xl border border-ink-100 bg-white/80 p-5 shadow-sm">
      <p class="m-0 text-xs uppercase tracking-[0.18em] text-ink-500">Employment</p>
      <h2 class="mt-2 font-display text-2xl text-ink-900">Top County Sectors</h2>
      <ul id="ga-employers" class="mt-4 space-y-2 text-sm text-ink-700"></ul>
    </article>

    <article class="rounded-2xl border border-ink-100 bg-white/80 p-5 shadow-sm">
      <p class="m-0 text-xs uppercase tracking-[0.18em] text-ink-500">Weather</p>
      <h2 class="mt-2 font-display text-2xl text-ink-900">Current Conditions</h2>
      <dl id="ga-weather" class="mt-4 space-y-2 text-sm text-ink-700"></dl>
    </article>
  </section>

  <section class="mt-8 grid gap-6 lg:grid-cols-2">
    <article class="rounded-2xl border border-ink-100 bg-white/80 p-5 shadow-sm">
      <p class="m-0 text-xs uppercase tracking-[0.18em] text-ink-500">Assisted Housing</p>
      <h2 class="mt-2 font-display text-2xl text-ink-900">HUD Context</h2>
      <div class="mt-4 grid grid-cols-2 gap-3 text-sm">
        <div class="rounded-lg border border-ink-100 bg-paper p-3">
          <p class="m-0 text-xs uppercase tracking-[0.14em] text-ink-500">LIHTC Nearby</p>
          <p id="ga-lihtc-count" class="mt-1 text-xl font-display text-ink-900">-</p>
        </div>
        <div class="rounded-lg border border-ink-100 bg-paper p-3">
          <p class="m-0 text-xs uppercase tracking-[0.14em] text-ink-500">Public Housing</p>
          <p id="ga-public-housing-count" class="mt-1 text-xl font-display text-ink-900">-</p>
        </div>
      </div>
      <p id="ga-voucher-tract" class="mt-4 text-sm text-ink-700">-</p>
      <ul id="ga-housing-list" class="mt-3 space-y-2 text-sm text-ink-700"></ul>
    </article>

    <article class="rounded-2xl border border-ink-100 bg-white/80 p-5 shadow-sm">
      <p class="m-0 text-xs uppercase tracking-[0.18em] text-ink-500">Quick Listing Jump-Off</p>
      <h2 class="mt-2 font-display text-2xl text-ink-900">External Listing Sites</h2>
      <p class="mt-2 text-sm text-ink-700">
        This free MVP does not ingest MLS listing photos directly. Use these links for live listing
        galleries, then bring the address back here for scoring and context.
      </p>
      <div class="mt-4 flex flex-wrap gap-2 text-sm">
        <a
          id="ga-zillow-link"
          class="rounded-full border border-ink-100 bg-paper px-3 py-1.5 text-ink-700 no-underline hover:border-accent hover:text-accent"
          href="https://www.zillow.com/homes/Atlanta,-GA_rb/"
          rel="noopener noreferrer"
          target="_blank"
        >
          Open Zillow Search
        </a>
        <a
          id="ga-google-link"
          class="rounded-full border border-ink-100 bg-paper px-3 py-1.5 text-ink-700 no-underline hover:border-accent hover:text-accent"
          href="https://www.google.com/maps/search/Atlanta%20GA%20homes"
          rel="noopener noreferrer"
          target="_blank"
        >
          Open Maps Search
        </a>
      </div>
      <p class="mt-4 text-xs text-ink-500">
        Data sources: ArcGIS Geocoding, FCC Block API, Census ACS/CBP, OpenStreetMap Overpass,
        HUD ArcGIS layers, Open-Meteo.
      </p>
    </article>
  </section>

  <section class="mt-8 rounded-2xl border border-ink-100 bg-white/80 p-5 shadow-sm">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <div>
        <p class="m-0 text-xs uppercase tracking-[0.18em] text-ink-500">Browse Specific Properties</p>
        <h2 class="mt-2 font-display text-2xl text-ink-900">Nearby Listing-Like Records</h2>
        <p class="mt-2 max-w-3xl text-sm text-ink-700">
          Free mode uses public tax parcel records as a browseable listing proxy. You can filter by
          appraised value, unit count, and keywords, then jump to Zillow or Maps per address.
        </p>
      </div>
      <p id="ga-listings-source" class="rounded-full bg-accentSoft px-3 py-1 text-xs text-accent">
        Source: waiting for search
      </p>
    </div>

    <div class="mt-4 grid gap-3 md:grid-cols-6">
      <label class="flex flex-col gap-1 text-xs text-ink-500">
        Min Appraised
        <input
          id="ga-listing-min"
          type="number"
          min="0"
          step="1000"
          class="rounded-lg border border-ink-200 bg-paper px-3 py-2 text-sm text-ink-900"
          placeholder="150000"
        />
      </label>

      <label class="flex flex-col gap-1 text-xs text-ink-500">
        Max Appraised
        <input
          id="ga-listing-max"
          type="number"
          min="0"
          step="1000"
          class="rounded-lg border border-ink-200 bg-paper px-3 py-2 text-sm text-ink-900"
          placeholder="900000"
        />
      </label>

      <label class="flex flex-col gap-1 text-xs text-ink-500">
        Min Units
        <input
          id="ga-listing-units"
          type="number"
          min="0"
          step="1"
          class="rounded-lg border border-ink-200 bg-paper px-3 py-2 text-sm text-ink-900"
          placeholder="1"
        />
      </label>

      <label class="flex flex-col gap-1 text-xs text-ink-500 md:col-span-2">
        Address / Neighborhood
        <input
          id="ga-listing-text"
          type="text"
          class="rounded-lg border border-ink-200 bg-paper px-3 py-2 text-sm text-ink-900"
          placeholder="Peachtree, Midtown, condo"
        />
      </label>

      <label class="flex flex-col gap-1 text-xs text-ink-500">
        Sort
        <select
          id="ga-listing-sort"
          class="rounded-lg border border-ink-200 bg-paper px-3 py-2 text-sm text-ink-900"
        >
          <option value="distance-asc">Nearest first</option>
          <option value="value-desc">Highest value</option>
          <option value="value-asc">Lowest value</option>
          <option value="units-desc">Most units</option>
        </select>
      </label>

      <label class="flex items-center gap-2 self-end pb-2 text-xs text-ink-600 md:col-span-1">
        <input
          id="ga-listing-on-market"
          type="checkbox"
          class="h-4 w-4 rounded border-ink-300 text-accent focus:ring-accent"
        />
        On market only
      </label>
    </div>

    <div class="mt-3 flex flex-wrap items-center gap-2">
      <button
        id="ga-listing-reset"
        type="button"
        class="rounded-full border border-ink-200 bg-paper px-3 py-1.5 text-xs text-ink-700 hover:border-accent hover:text-accent"
      >
        Reset filters
      </button>
      <p id="ga-listings-summary" class="m-0 text-xs text-ink-500">Run a search to load properties.</p>
    </div>

    <p id="ga-on-market-status" class="mt-2 text-xs text-ink-500">
      On-market feed status: waiting for search.
    </p>

    <div id="ga-listing-list" class="mt-4 grid gap-3 md:grid-cols-2"></div>
  </section>

  <noscript>
    <section class="mt-8 rounded-xl border border-warning/40 bg-white/80 p-4 text-sm text-warning">
      JavaScript is required for live data queries on this page.
    </section>
  </noscript>

  <script>
    // @ts-nocheck
    const publicRentcastApiKey = `${import.meta.env.PUBLIC_RENTCAST_API_KEY || ''}`.trim();

    const SEARCH_RADIUS_MILES = 2;
    const HUD_RADIUS_MILES = 3;
    const MAP_AMENITY_LIMIT = 25;
    const MAP_HOUSING_LIMIT = 18;
    const PARCEL_RADIUS_MILES = 2.5;
    const PARCEL_FETCH_LIMIT = 220;
    const PARCEL_RENDER_LIMIT = 48;

    const atlantaParcelsService = {
      query: 'https://gis.atlantaga.gov/dpcd/rest/services/AdministrativeArea/TaxParcel/MapServer/0/query',
      fields: {
        address: 'SITEADDRESS',
        value: 'TOT_APPR',
        units: 'LIVUNITS',
        classDescription: 'CLASSDSCRP',
        neighborhood: 'NEIGHBORHOOD',
        parcelId: 'PARCELID',
        taxYear: 'TAXYEAR',
      },
      outFields:
        'PARCELID,SITEADDRESS,CLASSDSCRP,TOT_APPR,LANDASSESS,IMPRASSESS,TAXYEAR,NEIGHBORHOOD,LIVUNITS,PRPRTYDSCRP,SITEZIP',
    };

    const dekalbParcelsService = {
      query:
        'https://services2.arcgis.com/IxVN2oUE9EYLSnPE/arcgis/rest/services/Tax_Parcels2/FeatureServer/0/query',
      fields: {
        address: 'SITEADDRESS',
        value: 'TOTAPR1',
        units: null,
        classDescription: 'CLASSDSCRP',
        neighborhood: 'NGHBRHDCD',
        parcelId: 'PARCELID',
        taxYear: 'LGLSTARTDT',
      },
      outFields:
        'PARCELID,SITEADDRESS,CLASSDSCRP,USEDSCRP,TOTAPR1,LGLSTARTDT,STATUS,LANDUSE,ZONING,PRPRTYDSCRP,NGHBRHDCD',
    };

    const fultonParcelsService = {
      query:
        'https://services1.arcgis.com/AQDHTHDrZzfsFsB5/arcgis/rest/services/Tax_Parcels/FeatureServer/0/query',
      fields: {
        address: 'Address',
        value: null,
        units: 'LivUnits',
        classDescription: 'ClassCode',
        neighborhood: 'NbrHood',
        parcelId: 'ParcelID',
        taxYear: 'TaxYear',
      },
      outFields: 'ParcelID,Address,TaxYear,ClassCode,LUCode,LivUnits,NbrHood,Owner',
    };

    const cobbParcelsService = {
      query:
        'https://services2.arcgis.com/hE9igMm8RoNeQRbh/arcgis/rest/services/Cobb_Parcels/FeatureServer/0/query',
      fields: {
        address: 'FULL_ADDR',
        value: null,
        units: null,
        classDescription: 'Municipality',
        neighborhood: 'Municipality',
        parcelId: 'PIN',
        taxYear: null,
      },
      outFields: 'PIN,FULL_ADDR,Municipality,ADDR,STNAME,SUFF,PREDIREC,POSTDIREC',
    };

    const gwinnettParcelsService = {
      query:
        'https://services3.arcgis.com/RfpmnkSAQleRbndX/arcgis/rest/services/Property_and_Tax/FeatureServer/0/query',
      fields: {
        address: 'ADDRESS',
        value: null,
        units: null,
        classDescription: 'PARCELTYPE',
        neighborhood: null,
        parcelId: 'PIN',
        taxYear: null,
      },
      outFields: 'PIN,ADDRESS,PARCELTYPE,LOT,TAXPIN,LRSN',
    };

    const geocoderEndpoint =
      'https://geocode.arcgis.com/arcgis/rest/services/World/GeocodeServer/findAddressCandidates';
    const fccBlockEndpoint = 'https://geo.fcc.gov/api/census/block/find';
    const acsEndpoint = 'https://api.census.gov/data/2023/acs/acs5';
    const cbpEndpoint = 'https://api.census.gov/data/2023/cbp';
    const overpassEndpoints = [
      'https://overpass.kumi.systems/api/interpreter',
      'https://overpass-api.de/api/interpreter',
      'https://lz4.overpass-api.de/api/interpreter',
    ];
    const weatherEndpoint = 'https://api.open-meteo.com/v1/forecast';

    const hudServices = {
      vouchers:
        'https://services.arcgis.com/VTyQ9soqVukalItT/arcgis/rest/services/Housing_Choice_Vouchers_by_Tract/FeatureServer/0/query',
      lihtc: 'https://services.arcgis.com/VTyQ9soqVukalItT/arcgis/rest/services/LIHTC/FeatureServer/0/query',
      publicHousing:
        'https://services.arcgis.com/VTyQ9soqVukalItT/arcgis/rest/services/Public_Housing_Developments/FeatureServer/0/query',
    };

    const formatInteger = new Intl.NumberFormat('en-US', { maximumFractionDigits: 0 });
    const formatCurrency = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      maximumFractionDigits: 0,
    });

    const elements = {
      form: document.getElementById('ga-search-form'),
      input: document.getElementById('ga-search-input'),
      submit: document.getElementById('ga-search-submit'),
      status: document.getElementById('ga-status'),
      warning: document.getElementById('ga-warning'),
      location: document.getElementById('ga-location'),
      countyTract: document.getElementById('ga-county-tract'),
      homeValue: document.getElementById('ga-home-value'),
      income: document.getElementById('ga-income'),
      accessScore: document.getElementById('ga-access-score'),
      groceryCount: document.getElementById('ga-grocery-count'),
      marketCount: document.getElementById('ga-market-count'),
      amenityList: document.getElementById('ga-amenity-list'),
      demographics: document.getElementById('ga-demographics'),
      employers: document.getElementById('ga-employers'),
      weather: document.getElementById('ga-weather'),
      lihtcCount: document.getElementById('ga-lihtc-count'),
      publicHousingCount: document.getElementById('ga-public-housing-count'),
      voucherTract: document.getElementById('ga-voucher-tract'),
      housingList: document.getElementById('ga-housing-list'),
      zillowLink: document.getElementById('ga-zillow-link'),
      googleLink: document.getElementById('ga-google-link'),
      map: document.getElementById('ga-map'),
      listingsSource: document.getElementById('ga-listings-source'),
      listingsSummary: document.getElementById('ga-listings-summary'),
      listingList: document.getElementById('ga-listing-list'),
      listingMin: document.getElementById('ga-listing-min'),
      listingMax: document.getElementById('ga-listing-max'),
      listingUnits: document.getElementById('ga-listing-units'),
      listingText: document.getElementById('ga-listing-text'),
      listingSort: document.getElementById('ga-listing-sort'),
      listingOnMarket: document.getElementById('ga-listing-on-market'),
      listingReset: document.getElementById('ga-listing-reset'),
      onMarketStatus: document.getElementById('ga-on-market-status'),
      presets: Array.from(document.querySelectorAll('.ga-preset')),
    };

    const listingState = {
      records: [],
      filtered: [],
      sourceLabel: 'waiting for search',
      center: null,
      onMarketByAddress: new Set(),
      onMarketEnabled: false,
    };

    const mapState = {
      loading: null,
      L: null,
      map: null,
      layer: null,
    };

    function clamp(value, min, max) {
      return Math.min(max, Math.max(min, value));
    }

    function toNumber(value) {
      if (value === null || value === undefined) {
        return null;
      }

      if (typeof value === 'string' && value.trim() === '') {
        return null;
      }

      const parsed = Number(value);
      if (!Number.isFinite(parsed) || parsed < 0) {
        return null;
      }

      return parsed;
    }

    function formatNumber(value) {
      if (value === null || value === undefined) {
        return 'N/A';
      }

      return formatInteger.format(value);
    }

    function formatMoney(value) {
      if (value === null || value === undefined) {
        return 'N/A';
      }

      return formatCurrency.format(value);
    }

    function formatPercent(value) {
      if (value === null || value === undefined) {
        return 'N/A';
      }

      return `${(value * 100).toFixed(1)}%`;
    }

    function formatMiles(value) {
      if (!Number.isFinite(value)) {
        return 'N/A';
      }

      return `${value.toFixed(2)} mi`;
    }

    function setStatus(message, tone = 'neutral') {
      elements.status.textContent = message;
      elements.status.className = 'mt-4 text-sm';

      if (tone === 'error') {
        elements.status.classList.add('text-red-700');
        return;
      }

      if (tone === 'success') {
        elements.status.classList.add('text-success');
        return;
      }

      elements.status.classList.add('text-ink-700');
    }

    const warningMessages = new Set();

    function renderWarnings() {
      elements.warning.textContent = Array.from(warningMessages).join(' ');
    }

    function setWarning(message = '') {
      warningMessages.clear();
      if (String(message || '').trim()) {
        warningMessages.add(String(message).trim());
      }
      renderWarnings();
    }

    function addWarning(message = '') {
      if (!String(message || '').trim()) {
        return;
      }

      warningMessages.add(String(message).trim());
      renderWarnings();
    }

    function haversineMiles(lat1, lon1, lat2, lon2) {
      const toRad = (value) => (value * Math.PI) / 180;
      const earthRadiusMiles = 3958.8;
      const dLat = toRad(lat2 - lat1);
      const dLon = toRad(lon2 - lon1);
      const a =
        Math.sin(dLat / 2) * Math.sin(dLat / 2) +
        Math.cos(toRad(lat1)) *
          Math.cos(toRad(lat2)) *
          Math.sin(dLon / 2) *
          Math.sin(dLon / 2);
      const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
      return earthRadiusMiles * c;
    }

    async function fetchJson(url, timeoutMs = 30000) {
      const controller = new AbortController();
      const timer = setTimeout(() => controller.abort(), timeoutMs);

      try {
        const response = await fetch(url, {
          method: 'GET',
          mode: 'cors',
          signal: controller.signal,
        });

        if (!response.ok) {
          throw new Error(`Request failed (${response.status})`);
        }

        return await response.json();
      } finally {
        clearTimeout(timer);
      }
    }

    async function fetchJsonWithRetry(url, options = {}) {
      const {
        attempts = 3,
        timeoutMs = 30000,
        retryStatuses = [429, 500, 502, 503, 504],
        initialDelayMs = 400,
      } = options;

      let lastError = null;

      for (let attempt = 1; attempt <= attempts; attempt += 1) {
        try {
          return await fetchJson(url, timeoutMs);
        } catch (error) {
          lastError = error;
          const message = error instanceof Error ? error.message : String(error);
          const statusMatch = message.match(/\((\d+)\)/);
          const statusCode = statusMatch ? Number(statusMatch[1]) : null;
          const isAbort = message.toLowerCase().includes('abort');
          const isRetriable =
            isAbort || (statusCode !== null && retryStatuses.includes(statusCode));

          if (!isRetriable || attempt === attempts) {
            break;
          }

          const delay = initialDelayMs * Math.pow(2, attempt - 1);
          await new Promise((resolve) => setTimeout(resolve, delay));
        }
      }

      throw lastError;
    }

    async function geocode(query) {
      const params = new URLSearchParams({
        SingleLine: query,
        f: 'pjson',
        maxLocations: '1',
        outFields: 'Match_addr,Addr_type,City,Region,Postal',
      });

      const data = await fetchJson(`${geocoderEndpoint}?${params.toString()}`);
      const candidate = Array.isArray(data.candidates) ? data.candidates[0] : null;

      if (!candidate || !candidate.location) {
        throw new Error('No geocoding match found for that query.');
      }

      return {
        label: candidate.address || query,
        latitude: candidate.location.y,
        longitude: candidate.location.x,
        region: candidate.attributes?.Region || '',
        city: candidate.attributes?.City || '',
      };
    }

    async function getFips(latitude, longitude) {
      const params = new URLSearchParams({
        latitude: latitude.toFixed(6),
        longitude: longitude.toFixed(6),
        format: 'json',
      });

      const data = await fetchJson(`${fccBlockEndpoint}?${params.toString()}`);
      const blockFips = data?.Block?.FIPS;

      if (typeof blockFips !== 'string' || blockFips.length !== 15) {
        throw new Error('Unable to determine census tract for this location.');
      }

      const state = blockFips.slice(0, 2);
      const county = blockFips.slice(2, 5);
      const tract = blockFips.slice(5, 11);

      return {
        blockFips,
        state,
        county,
        tract,
        tractGeoid: `${state}${county}${tract}`,
        countyName: data?.County?.name || 'Unknown County',
      };
    }

    async function getAcsData(geo) {
      const variables = [
        'NAME',
        'B01003_001E',
        'B19013_001E',
        'B25077_001E',
        'B25064_001E',
        'B25002_001E',
        'B25002_002E',
        'B15003_001E',
        'B15003_022E',
        'B15003_023E',
        'B15003_024E',
        'B15003_025E',
      ];

      const params = new URLSearchParams({
        get: variables.join(','),
        for: `tract:${geo.tract}`,
        in: `state:${geo.state} county:${geo.county}`,
      });

      const rows = await fetchJson(`${acsEndpoint}?${params.toString()}`);
      if (!Array.isArray(rows) || rows.length < 2) {
        return null;
      }

      const headers = rows[0];
      const values = rows[1];
      const record = {};

      headers.forEach((header, index) => {
        record[header] = values[index];
      });

      const educationTotal = toNumber(record.B15003_001E);
      const bachelorPlus =
        (toNumber(record.B15003_022E) || 0) +
        (toNumber(record.B15003_023E) || 0) +
        (toNumber(record.B15003_024E) || 0) +
        (toNumber(record.B15003_025E) || 0);

      const occupiedUnits = toNumber(record.B25002_002E);
      const housingUnits = toNumber(record.B25002_001E);

      return {
        name: record.NAME || 'Unknown tract',
        population: toNumber(record.B01003_001E),
        medianIncome: toNumber(record.B19013_001E),
        medianHomeValue: toNumber(record.B25077_001E),
        medianRent: toNumber(record.B25064_001E),
        housingUnits,
        occupiedUnits,
        occupancyRate:
          housingUnits && occupiedUnits !== null && housingUnits > 0
            ? occupiedUnits / housingUnits
            : null,
        bachelorPlusRate:
          educationTotal && educationTotal > 0 ? bachelorPlus / educationTotal : null,
      };
    }

    async function getCountyEmployment(geo) {
      const params = new URLSearchParams({
        get: 'NAICS2017,NAICS2017_LABEL,ESTAB,EMP',
        for: `county:${geo.county}`,
        in: `state:${geo.state}`,
      });

      const rows = await fetchJson(`${cbpEndpoint}?${params.toString()}`);
      if (!Array.isArray(rows) || rows.length < 2) {
        return [];
      }

      const headers = rows[0];
      const entries = rows
        .slice(1)
        .map((row) => {
          const item = {};
          headers.forEach((header, index) => {
            item[header] = row[index];
          });
          return item;
        })
        .filter((item) => /^\d{2}$/.test(item.NAICS2017 || '') && item.NAICS2017 !== '00')
        .map((item) => ({
          code: item.NAICS2017,
          label: item.NAICS2017_LABEL || 'Unknown sector',
          establishments: toNumber(item.ESTAB),
          employment: toNumber(item.EMP),
        }))
        .filter((item) => item.employment !== null)
        .sort((a, b) => (b.employment || 0) - (a.employment || 0));

      return entries.slice(0, 8);
    }

    async function getAmenities(latitude, longitude) {
      const radiusMeters = Math.round(SEARCH_RADIUS_MILES * 1609.34);
      let data = null;
      let lastError = null;

      const fullQuery = `[out:json][timeout:25];(nwr(around:${radiusMeters},${latitude},${longitude})[shop=supermarket];nwr(around:${radiusMeters},${latitude},${longitude})[shop=grocery];nwr(around:${radiusMeters},${latitude},${longitude})[amenity=marketplace];);out center tags;`;
      const lightQuery = `[out:json][timeout:15];(node(around:${radiusMeters},${latitude},${longitude})[shop=supermarket];node(around:${radiusMeters},${latitude},${longitude})[shop=grocery];node(around:${radiusMeters},${latitude},${longitude})[amenity=marketplace];);out tags;`;

      for (const query of [fullQuery, lightQuery]) {
        const params = new URLSearchParams({ data: query });

        for (const endpoint of overpassEndpoints) {
          try {
            data = await fetchJsonWithRetry(`${endpoint}?${params.toString()}`, {
              attempts: 1,
              timeoutMs: 35000,
            });
            break;
          } catch (error) {
            lastError = error;
          }
        }

        if (data) {
          break;
        }
      }

      if (!data) {
        throw lastError || new Error('Amenities source is temporarily unavailable.');
      }

      const seen = new Set();
      const items = [];

      for (const element of Array.isArray(data.elements) ? data.elements : []) {
        const lat = element.lat ?? element.center?.lat;
        const lon = element.lon ?? element.center?.lon;
        const tags = element.tags || {};

        if (!Number.isFinite(lat) || !Number.isFinite(lon)) {
          continue;
        }

        let kind = 'Other';
        if (tags.shop === 'supermarket' || tags.shop === 'grocery') {
          kind = 'Grocery';
        } else if (tags.amenity === 'marketplace') {
          kind = 'Market';
        }

        const name = tags.name || `${kind} point`;
        const key = `${name}|${kind}|${lat.toFixed(5)}|${lon.toFixed(5)}`;
        if (seen.has(key)) {
          continue;
        }

        seen.add(key);

        items.push({
          id: element.id,
          kind,
          name,
          latitude: lat,
          longitude: lon,
          distanceMiles: haversineMiles(latitude, longitude, lat, lon),
        });
      }

      return items.sort((a, b) => a.distanceMiles - b.distanceMiles);
    }

    async function getHudVouchersByTract(tractGeoid) {
      const params = new URLSearchParams({
        where: `GEOID='${tractGeoid}'`,
        outFields: 'GEOID,HCV_PUBLIC,HCV_PUBLIC_PCT',
        returnGeometry: 'false',
        f: 'json',
      });

      const data = await fetchJson(`${hudServices.vouchers}?${params.toString()}`);
      const feature = Array.isArray(data.features) ? data.features[0] : null;
      if (!feature || !feature.attributes) {
        return null;
      }

      return {
        vouchers: toNumber(feature.attributes.HCV_PUBLIC),
