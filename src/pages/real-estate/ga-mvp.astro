    function computeAccessScore(amenities) {
      const groceries = amenities.filter((item) => item.kind === 'Grocery');
      const markets = amenities.filter((item) => item.kind === 'Market');

      const nearestGrocery = groceries[0]?.distanceMiles ?? SEARCH_RADIUS_MILES;
      const nearestMarket = markets[0]?.distanceMiles ?? SEARCH_RADIUS_MILES;
      const groceriesWithinMile = groceries.filter((item) => item.distanceMiles <= 1).length;
      const marketsWithinTwoMiles = markets.filter((item) => item.distanceMiles <= 2).length;

      const rawScore =
        100 -
        nearestGrocery * 28 -
        nearestMarket * 16 +
        groceriesWithinMile * 9 +
        marketsWithinTwoMiles * 7;

      return {
        score: clamp(Math.round(rawScore), 0, 100),
        groceryCount: groceries.length,
        marketCount: markets.length,
      };
    }

