---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Alert from '../../components/Alert.astro';
import YoutubeEmbed from '../../components/YoutubeEmbed.astro';
import TableOfContents from '../../components/TableOfContents.astro';

export async function getStaticPaths() {
  const entries = await getCollection('curriculum');

  return entries
    .filter((entry) => entry.data.status === 'published')
    .map((entry) => ({
      params: { slug: entry.slug.replace(/^\/+|\/+$/g, '') },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const isPublic = entry.data.visibility === 'public';

if (!isPublic) {
  return Astro.redirect('/');
}

const words = entry.body.split(/\s+/).length;
const readingMinutes = Math.max(1, Math.round(words / 230));
---

<BaseLayout title={`${entry.data.title} | Field Notes Curriculum`} description={entry.data.summary}>
  <article class="mx-auto max-w-3xl rounded-2xl border border-ink-100 bg-white/80 p-6 shadow-sm md:p-8">
    <header class="mb-8 border-b border-ink-100 pb-5">
      <p class="m-0 text-xs uppercase tracking-[0.18em] text-ink-500">Curriculum Entry</p>
      <h1 class="mt-3 font-display text-4xl text-ink-900">{entry.data.title}</h1>
      <p class="mt-3 text-lg text-ink-700">{entry.data.summary}</p>
      <p class="mt-3 text-xs text-ink-500">{readingMinutes} min read</p>
    </header>

    <TableOfContents headings={headings} />

    <div class="prose prose-ink max-w-none prose-headings:font-display prose-a:text-accent">
      <Content components={{ Alert, YoutubeEmbed }} />
    </div>
  </article>
</BaseLayout>
