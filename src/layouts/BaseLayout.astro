---
import '../styles/global.css';

type Props = {
  title: string;
  description?: string;
};

const {
  title,
  description = 'Curated curriculum notes and references.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <header class="sticky top-0 z-20 border-b border-ink-100 bg-paper/95 backdrop-blur">
      <div class="mx-auto flex w-full max-w-5xl items-center justify-between px-4 py-3 md:px-6">
        <a href="/" class="font-display text-lg text-ink-900 no-underline">Field Notes Curriculum</a>
        <nav class="text-sm text-ink-700">
          <a class="no-underline hover:text-accent" href="/">All Curriculum</a>
        </nav>
      </div>
    </header>

    <main class="mx-auto w-full max-w-5xl px-4 py-8 md:px-6 md:py-12">
      <slot />
    </main>
  </body>
</html>
